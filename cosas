function selectAvatar(avatar) {
    currentAvatar = avatar;

    document.getElementById('avatar1').classList.remove('selected');
    document.getElementById('avatar2').classList.remove('selected');

    if (avatar === 'boy') {
        document.getElementById('avatar1').classList.add('selected');
        document.getElementById('selectedAvatarText').innerHTML = 'Avatar: <img src="boy.png" style="height:16px;vertical-align:middle;"> Chico';
    } else {
        document.getElementById('avatar2').classList.add('selected');
        document.getElementById('selectedAvatarText').innerHTML = 'Avatar: <img src="girl.png" style="height:16px;vertical-align:middle;"> Chica';
    }
}
